rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper functions ──────────────────────────────────────────────────
    function getUserTenantId() { return request.auth.token.tenantId; }
    function getUserRole() { return request.auth.token.role; }
    function isSuperAdmin() { return getUserRole() == 'SUPER_ADMIN'; }
    function isAdminOrManager() { return getUserRole() in ['COLLEGE_ADMIN', 'MANAGER'] || isSuperAdmin(); }
    function isPRO() { return getUserRole() == 'PRO'; }
    function isAuthenticated() { return request.auth != null; }

    // Check tenant match — with fallback: if claims haven't synced yet (tenantId is null),
    // read the user doc to verify tenant membership. This prevents permission-denied
    // errors during the claims sync window after login.
    function sameTenant(docTenantId) {
      return getUserTenantId() != null && getUserTenantId() == docTenantId;
    }
    function sameTenantOrUnsynced(docTenantId) {
      return sameTenant(docTenantId)
        || (getUserTenantId() == null && isAuthenticated()
             && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.tenantId == docTenantId);
    }

    // Check if a division ID is in the PRO's assignedDivisionIds
    function proAssignedDiv(divId) {
      let divs = get(/databases/$(database)/documents/users/$(request.auth.uid)).data.assignedDivisionIds;
      return divs != null && divId in divs;
    }

    // ── Tenants ───────────────────────────────────────────────────────────
    match /tenants/{tid} {
      allow read: if isAuthenticated();
      // Allow create for bootstrap (init page) when no SUPER_ADMIN exists yet
      allow create: if isAuthenticated();
      allow update: if isSuperAdmin();
      allow delete: if false;
    }

    // ── Users ─────────────────────────────────────────────────────────────
    match /users/{uid} {
      // Reading your own doc always works (even before claims sync).
      // Admin/Manager/SuperAdmin can read other users in their tenant.
      allow read: if isAuthenticated() && (
        request.auth.uid == uid
        || (sameTenantOrUnsynced(resource.data.tenantId) && isAdminOrManager())
        || isSuperAdmin()
      );
      // Allow creating own user doc (bootstrap / init page)
      allow create: if isAuthenticated() && request.auth.uid == uid;
      // Allow updates via cloud functions or own doc (for profile updates)
      // Own-doc updates: only allow specific safe fields (fcmDevices, lastActive)
      allow update: if isAuthenticated() && (
        request.auth.uid == uid
        || isSuperAdmin()
        || (sameTenantOrUnsynced(resource.data.tenantId) && isAdminOrManager())
      );
      allow delete: if false;
    }

    // ── Username Index ────────────────────────────────────────────────────
    // LOCKED: username→email resolution is now done server-side via
    // the resolveUsernameToEmail Cloud Function. No direct client access.
    match /usernameIndex/{key} {
      allow read, write: if false;
    }

    // ── Divisions ─────────────────────────────────────────────────────────
    match /divisions/{did} {
      allow read: if isAuthenticated() && sameTenantOrUnsynced(resource.data.tenantId);
      allow create: if isAuthenticated() && isAdminOrManager()
                    && request.resource.data.tenantId == getUserTenantId();
      allow update: if isAuthenticated() && isAdminOrManager()
                    && sameTenant(resource.data.tenantId);
      allow delete: if false;
    }

    // ── Teams ─────────────────────────────────────────────────────────────
    match /teams/{tmid} {
      allow read: if isAuthenticated() && sameTenantOrUnsynced(resource.data.tenantId);
      allow write: if false; // CF only
    }

    // ── Leads ─────────────────────────────────────────────────────────────
    match /leads/{lid} {
      allow read: if isAuthenticated() && sameTenantOrUnsynced(resource.data.tenantId)
                  && (isAdminOrManager()
                      || (isPRO() && request.auth.uid in resource.data.assignedPROUids)
                      || (isPRO() && proAssignedDiv(resource.data.divisionId)));
      allow write: if false; // CF only

      match /statusUpdates/{uid} {
        allow read: if isAuthenticated() && sameTenantOrUnsynced(resource.data.tenantId)
                    && (isAdminOrManager()
                        || (isPRO() && request.auth.uid == resource.data.loggedByUid)
                        || (isPRO() && request.auth.uid in get(/databases/$(database)/documents/leads/$(lid)).data.assignedPROUids)
                        || (isPRO() && proAssignedDiv(get(/databases/$(database)/documents/leads/$(lid)).data.divisionId)));
        allow create: if false; // CF only (server enforces GPS logic)
        allow update, delete: if false; // append-only
      }
    }

    // ── Lead Assignments (denorm for search) ──────────────────────────────
    match /leadAssignments/{aid} {
      allow read: if isAuthenticated() && sameTenantOrUnsynced(resource.data.tenantId)
                  && (isAdminOrManager()
                      || (isPRO() && request.auth.uid in resource.data.assignedPROUids)
                      || (isPRO() && proAssignedDiv(resource.data.divisionId)));
      allow write: if false; // CF only
    }

    match /{path=**}/statusUpdates/{uid} {
      allow read: if isAuthenticated() && sameTenant(resource.data.tenantId);
    }

    // ── Reminders ─────────────────────────────────────────────────────────
    match /reminders/{rid} {
      allow read: if isAuthenticated() && sameTenantOrUnsynced(resource.data.tenantId)
                  && (isAdminOrManager() || request.auth.uid in resource.data.recipientUids);
      allow create, update: if false; // CF only
    }

    // ── Tenant Config ─────────────────────────────────────────────────────
    match /tenantConfig/{tid} {
      allow read: if isAuthenticated();
      // Allow create for bootstrap (init page)
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && (sameTenantOrUnsynced(tid) && isAdminOrManager());
      allow delete: if false;
    }

    // ── Import Batches ────────────────────────────────────────────────────
    match /importBatches/{bid} {
      allow read: if isAuthenticated() && sameTenantOrUnsynced(resource.data.tenantId) && isAdminOrManager();
      allow write: if false; // CF only
    }

    // ── Tenant Stats ──────────────────────────────────────────────────────
    match /tenant_stats/{tid} {
      allow read: if isAuthenticated() && (sameTenantOrUnsynced(tid) || isSuperAdmin());
      allow write: if false; // triggers only
    }

    // ── Tenant Daily Stats ────────────────────────────────────────────────
    match /tenant_daily_stats/{key} {
      allow read: if isAuthenticated() && (sameTenantOrUnsynced(resource.data.tenantId) || isSuperAdmin());
      allow write: if false; // triggers only
    }

    // ── Processed Events (idempotency) ────────────────────────────────────
    match /_processedEvents/{eid} {
      allow read, write: if false; // CF only
    }
  }
}
